PROJECT_NAME="Student Management System API"
API_V1_STR="/api/v1"

# Security
# Run "openssl rand -hex 32" to generate a secure secret key
SECRET_KEY="your-super-secret-key-change-this-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Database Configuration (MySQL)
MYSQL_SERVER=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DB=student_db

# Combined database URL. If left empty, the application will construct it
# from the MySQL fields above, or fall back to SQLite if they are not set.
# DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/student_db
DATABASE_URL=sqlite:///./student_management.db
